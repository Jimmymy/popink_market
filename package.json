{
  "name": "popink-market",
  "private": true,
  "packageManager": "npm@10.9.7",
  "engines": {
    "node": "22.22.2"
  },
  "scripts": {
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down",
    "backend:migrate": "npm exec --workspace=@dtc/backend -- medusa db:migrate",
    "dev": "npm -r dev",
    "build": "npm -r build",
    "start": "turbo start",
    "lint": "turbo lint",
    "test": "turbo test",
    "backend:seed": "turbo seed --filter=@dtc/backend",
    "backend:dev": "turbo dev --filter=@dtc/backend",
    "storefront:dev": "turbo dev --filter=@dtc/storefront"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.0.5",
      "@types/react-dom": "19.0.5"
    }
  },
  "devDependencies": {
    "turbo": "^2.0.14",
    "prettier": "^3.2.5"
  },
  "workspaces": [
    "apps/**",
    "!apps/backend/.medusa/**"
  ],
  "overrides": {
    "ajv": "^8.0.0"
  }
}
