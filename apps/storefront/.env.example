# Publishable API key generated by Medusa for the local demo seed.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=replace-with-local-publishable-key

# URL of the Medusa backend API server.
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# Default region code to use for the storefront.
NEXT_PUBLIC_DEFAULT_REGION=jp

# Base URL of the storefront.
NEXT_PUBLIC_BASE_URL=http://localhost:8000

# Stripe publishable key for payment processing. Leave empty for demo mode.
NEXT_PUBLIC_STRIPE_KEY=

NODE_ENV=development
