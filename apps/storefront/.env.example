# Publishable API key generated by Medusa for the local demo seed.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=replace-with-local-publishable-key

# Public API base for browsers. Leave empty to use the current site origin
# so LAN clients can call the local machine through the built-in proxy.
NEXT_PUBLIC_MEDUSA_BACKEND_URL=

# Internal API base used by the Next.js server and middleware on this machine.
MEDUSA_BACKEND_INTERNAL_URL=http://127.0.0.1:9000

# Default region code to use for the storefront.
NEXT_PUBLIC_DEFAULT_REGION=jp

# Base URL used for metadata and absolute links in local demo mode.
NEXT_PUBLIC_BASE_URL=http://127.0.0.1:8080

# Stripe publishable key for payment processing. Leave empty for demo mode.
NEXT_PUBLIC_STRIPE_KEY=

NODE_ENV=development
